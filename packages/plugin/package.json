{
  "name": "@manifester/plugin",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    },
    "./runner-contract": {
      "types": "./src/runtime/generated-api-contract.ts",
      "import": "./dist/runner-contract.mjs"
    }
  },
  "scripts": {
    "build": "vite build --mode library && vite build --mode runner-contract",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@openai/codex-sdk": "0.144.5",
    "acorn": "8.17.0",
    "acorn-walk": "8.3.5",
    "csv-parse": "7.0.1",
    "fastify": "5.10.0",
    "parse5": "8.0.1",
    "postcss": "8.5.14",
    "read-excel-file": "9.3.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  }
}
